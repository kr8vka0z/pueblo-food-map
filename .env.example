# Public (client) — safe to expose. Inlined into the client bundle at BUILD time by `next build`.
# Set as BUILD variables: Cloudflare dashboard → Workers & Pages → pueblo-food-map → Settings → Build → Build variables.
# Workers Builds has ONE shared build-variable set (single `production` environment — no separate Preview
# environment; that's a Cloudflare Pages concept). The same build vars apply to prod deploys and PR preview builds.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxx
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Server-only — never commit real values. Read by the Worker at RUNTIME (request time), not at build time.
# Set as runtime Secrets: Settings → Variables and Secrets (encrypted secret_text), or `wrangler secret put`.
RESEND_API_KEY=
TURNSTILE_SECRET_KEY=

# Dev scripts only (scripts/scrub-osm-venues.ts, scripts/geocode-osm-missing.py): the Mapbox
# full-scope (sk) token used for reverse-geocoding. Never in the client bundle. Provide it as a
# 1Password reference in a gitignored .env.local and run scripts via `op run --env-file=.env.local`.
MAPBOX_TOKEN=

# Admin gate (Cloudflare Access, #237) — runtime, server-only. Set ONLY after the
# live CF Access application exists (Zero Trust dashboard). Until BOTH are set the
# admin surface fails closed (denies every request) by design — not a bug.
# CF_ACCESS_TEAM_DOMAIN: include the scheme, NO trailing slash. A trailing slash
# makes every real token fail issuer validation, which presents as a baffling
# "all admin requests denied" at wire-up.
CF_ACCESS_TEAM_DOMAIN=https://your-team.cloudflareaccess.com
CF_ACCESS_AUD=

# Better Auth engine (#314 Phase 1) — runtime, server-only. Signs/encrypts
# sessions, tokens, and passkey challenges; all state lives in the ADMIN_DB
# D1 database (no Workers KV). NOT yet wired into any login flow or route
# gate — Cloudflare Access (above) is still what actually protects the
# admin surface through this phase. Generate a local dev value with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Store the real value in .env.local (gitignored, same convention as
# RESEND_API_KEY above) — there is no 1Password item for this yet, since
# it's a locally-generated secret, not a rotated external credential. A
# production value is a separate later handoff (`wrangler secret put
# BETTER_AUTH_SECRET`), not part of this phase.
BETTER_AUTH_SECRET=

# Admin allowlist (#315 Phase 2) — runtime, server-only. Comma-separated
# email addresses permitted to hold an admin session at all; enforced at
# every Better Auth hook that can mint one (src/lib/adminAuthAllowlistPlugin.ts).
# Trimmed + lower-cased before comparison. If unset (or resolves to zero
# entries), src/lib/adminAllowlist.ts falls back to ["kysboyd@gmail.com"] —
# fails toward "only Kyle," never toward "everyone."
ADMIN_ALLOWLIST=kysboyd@gmail.com
