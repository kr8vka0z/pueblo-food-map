# Public (client) — safe to expose. Inlined into the client bundle at BUILD time by `next build`.
# Set as BUILD variables: Cloudflare dashboard → Workers & Pages → pueblo-food-map → Settings → Build → Build variables.
# Workers Builds has ONE shared build-variable set (single `production` environment — no separate Preview
# environment; that's a Cloudflare Pages concept). The same build vars apply to prod deploys and PR preview builds.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxx
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Server-only — never commit real values. Read by the Worker at RUNTIME (request time), not at build time.
# Set as runtime Secrets: Settings → Variables and Secrets (encrypted secret_text), or `wrangler secret put`.
RESEND_API_KEY=
TURNSTILE_SECRET_KEY=

# Admin gate (Cloudflare Access, #237) — runtime, server-only. Set ONLY after the
# live CF Access application exists (Zero Trust dashboard). Until BOTH are set the
# admin surface fails closed (denies every request) by design — not a bug.
# CF_ACCESS_TEAM_DOMAIN: include the scheme, NO trailing slash. A trailing slash
# makes every real token fail issuer validation, which presents as a baffling
# "all admin requests denied" at wire-up.
CF_ACCESS_TEAM_DOMAIN=https://your-team.cloudflareaccess.com
CF_ACCESS_AUD=
