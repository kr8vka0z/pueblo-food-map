# Public (client) — safe to expose
# Baked into the client bundle at build time.
# Set in Cloudflare Workers Builds → Settings → Variables and Secrets (Build vars, both Production + Preview).
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxx
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Server-only — never commit real values
# Set in Cloudflare Workers Builds → Settings → Variables and Secrets (both Production + Preview).
RESEND_API_KEY=
TURNSTILE_SECRET_KEY=
