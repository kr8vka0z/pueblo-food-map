# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# wrangler's own local-dev secret file (Better Auth's BETTER_AUTH_SECRET,
# #314 Phase 1) -- NOT covered by the .env* pattern above (different
# filename prefix: "dev" not "env"). Never commit a real secret value.
.dev.vars

# vercel
.vercel

# cloudflare / opennext
.open-next
.wrangler

# wrangler dry-run validation outdirs (#223 step 1 — never a real deploy)
.wrangler-dryrun/
.wrangler-dryrun-prod/

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code (project-local config, worktrees, personal overrides)
.claude/
.clone/

# Serena (local code-intelligence tooling — not part of the project)
.serena/

# generated SQL from scripts/seed-admin-db.ts — derivable from committed
# src/data/*.ts; regenerate with `bun run scripts/seed-admin-db.ts` (#237)
scripts/generated/

# Local ops secret-reference map -- keeps op:// paths out of this public repo
OPS-SECRETS.local.md
*.local.md
