{
  "name": "pueblo-food-map",
  "version": "0.1.7",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint && node scripts/check-banned.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "predeploy": "npm run lint && npm run design:drift && npm run typecheck && npm run test:ci",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "design:lint": "npx designmd lint DESIGN.md",
    "design:export": "npx designmd export --format css-tailwind DESIGN.md",
    "design:drift": "node scripts/check-design-drift.mjs",
    "seed:admin": "bun run scripts/seed-admin-db.ts"
  },
  "dependencies": {
    "@better-auth/passkey": "1.6.23",
    "better-auth": "1.6.23",
    "jose": "^6.2.3",
    "lucide-react": "^1.25.0",
    "mapbox-gl": "^3.26.0",
    "next": "16.2.11",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-map-gl": "^8.1.1",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "express": "4.22.2",
    "@better-auth/cli": "1.4.21",
    "@cloudflare/workers-types": "^5.20260723.1",
    "@google/design.md": "0.3.0",
    "@opennextjs/cloudflare": "1.20.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "axe-core": "^4.12.1",
    "better-sqlite3": "12.11.1",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0",
    "wrangler": "^4.107.0"
  },
  "overrides": {
    "sharp": ">=0.35.0"
  }
}
